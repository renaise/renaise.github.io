---
import Base from '../../layouts/Base.astro';
import { projectsExpanded } from '../../data/projects-expanded';

export function getStaticPaths() {
  return projectsExpanded.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { stage, lab, serviceSuite } = project;
---

<Base title={`${stage.title} — Lab`}>
  <div class="min-h-screen bg-[#111111] text-white/90 flex flex-col">
    <header class="relative z-10 flex items-center justify-between px-6 py-4 border-b border-white/10">
      <a href="/" class="text-[12px] uppercase tracking-widest text-white/60 hover:text-white/90">← Stage</a>
      <a href="/lab" class="text-[12px] uppercase tracking-widest text-white/60 hover:text-white/90">Lab index</a>
    </header>

    <main class="flex-1 px-6 py-10 max-w-2xl mx-auto w-full">
      <p class="text-[11px] uppercase tracking-[0.2em] text-white/40 mb-2">{stage.year} · {serviceSuite.join(' · ')}</p>
      <h1 class="text-2xl md:text-3xl font-medium uppercase tracking-wide text-white mb-4">{stage.title}</h1>
      <p class="text-sm text-white/70 leading-relaxed mb-8">{stage.description}</p>

      {stage.href && stage.href !== '#' && (
        <a
          href={stage.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-[12px] uppercase tracking-widest text-white/80 border border-white/20 rounded-full px-5 py-2.5 hover:bg-white/10 transition-colors"
        >
          View project
        </a>
      )}

      <section class="mt-14 pt-10 border-t border-white/10 space-y-6">
        <h2 class="text-[11px] uppercase tracking-[0.2em] text-white/40">Process</h2>
        <p class="text-lg font-medium uppercase tracking-wide text-white/90">{lab.title}</p>
        <p class="text-sm text-white/55">{lab.subtitle}</p>
        <p class="text-sm text-white/70 leading-relaxed">{lab.context}</p>
      </section>
    </main>

    <footer class="px-6 py-6 border-t border-white/10 text-center">
      <a href="mailto:krenaise@gmail.com" class="text-[11px] uppercase tracking-widest text-white/50 hover:text-white/80">
        Contact
      </a>
    </footer>
  </div>
</Base>
